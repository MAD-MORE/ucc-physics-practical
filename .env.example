# Prefer: npx neonctl env pull  (writes DATABASE_URL + Neon Auth URLs)
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth (enabled on the project; app login still uses student/admin JWT below)
NEON_AUTH_BASE_URL=https://ep-xxxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://ep-xxxx.neonauth.region.aws.neon.tech/neondb/auth/.well-known/jwks.json

# JWT secret for student/admin sessions (domain auth for index numbers + admin roles)
JWT_SECRET=change-me-to-a-long-random-string

PORT=3000
PRACTICAL_FEE=50.00
APP_BASE_URL=http://localhost:3000

# Paystack — put keys ONLY in .env (gitignored). Never commit real keys.
# Edit this file’s copy as .env, or run: npm run paystack:connect
# Then sync Ghana requirements: npm run paystack:sync
# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=GHS
PAYSTACK_CHANNELS=mobile_money,card
PAYSTACK_MOCK=false

